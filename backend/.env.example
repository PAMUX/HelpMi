DATABASE_URL="postgresql://postgres:PASSWORD@localhost:5432/helpmi?schema=public"

JWT_SECRET="change-this-in-production-use-a-long-random-string"
JWT_EXPIRES_IN="7d"

# --- OTP (P2-B) ---
OTP_EXPIRY_MINUTES=5
OTP_RESEND_COOLDOWN_SECONDS=60

ADMIN_PHONES="+94771234567"

# --- Payments (PayHere) ---
PAYHERE_MERCHANT_ID="your-merchant-id"
PAYHERE_MERCHANT_SECRET="your-merchant-secret"
PAYHERE_MODE="sandbox"

# --- SMS provider (P2-B): console | dialog | twilio ---
SMS_PROVIDER="console"
# Dialog/Mobitel-style HTTP gateway
SMS_GATEWAY_URL=""
SMS_GATEWAY_API_KEY=""
SMS_SENDER_ID="HelpMi"
# Twilio
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""

# --- Push provider (P2-A): console | fcm ---
PUSH_PROVIDER="console"
FCM_PROJECT_ID=""
# Service-account JSON (string) used to mint an OAuth token for FCM HTTP v1
FCM_SERVICE_ACCOUNT_JSON=""
# Legacy key (kept for reference; HTTP v1 is preferred)
FCM_SERVER_KEY="your-fcm-server-key"

# --- Object storage / uploads (P2-C): S3-compatible (AWS S3 | R2 | Spaces | MinIO) ---
S3_REGION="us-east-1"
# Leave empty for AWS S3; set for R2/Spaces/MinIO
S3_ENDPOINT=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
# true for MinIO / path-style endpoints
S3_FORCE_PATH_STYLE="false"
S3_PRIVATE_BUCKET="helpmi-kyc-private"
S3_PUBLIC_BUCKET="helpmi-public"
# Optional CDN/base URL for public objects
S3_PUBLIC_BASE_URL=""
UPLOAD_PRESIGN_TTL_SECONDS=300

# --- P3-A payouts ---
PAYHERE_PAYOUT_API_KEY=     # enables automated wallet payouts; empty = queue PROCESSING

# --- P3-C security ---
OTP_PEPPER=                 # optional server-side OTP hash pepper
CORS_ORIGINS=               # comma-separated allowed origins; empty = reflect any (dev)
