{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": [
      "ts-jest",
      {
        "isolatedModules": true,
        "tsconfig": {
          "module": "CommonJS",
          "moduleResolution": "node",
          "resolvePackageJsonExports": false,
          "verbatimModuleSyntax": false,
          "esModuleInterop": true
        }
      }
    ]
  },
  "moduleNameMapper": {
    "^(\\.{1,2}/.*)\\.js$": "$1"
  }
}
